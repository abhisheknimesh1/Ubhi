# ---------------------------------------------------------------------------
# Ubhi backend environment — COPY this file to ".env" and fill in real values.
# .env is gitignored. NEVER commit real secrets. These are PLACEHOLDERS only.
# ---------------------------------------------------------------------------

# Server
PORT=8090
NODE_ENV=development

# Auth — REQUIRED in production. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# CORS — comma-separated list of allowed origins, or "*" for any (dev only).
CORS_ORIGIN=*

# Database — leave BLANK to use the zero-config JSON file store (default).
# Set to a Postgres connection string in production to use PostgreSQL.
#   e.g. postgres://user:password@host:5432/ubhi
DATABASE_URL=

# Stripe — leave blank to disable payments (checkout returns configured:false).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (SMTP) — leave blank to disable outbound email (mailer logs instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@ubhi.example

# Seed owner account — used by "npm run seed" to create the first admin.
OWNER_EMAIL=owner@ubhi.example
OWNER_PASSWORD=change-me-now

# Shop economics
SHIPPING_FLAT=3.95
FREE_SHIP_THRESHOLD=50
